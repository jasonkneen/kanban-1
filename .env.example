# ══════════════════════════════════════════════════════════════════════════════
#  Cline Kanban — Docker Environment Configuration
#  Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Admin account (first-boot only) ──────────────────────────────────────────
#
# Created once when the container starts for the first time (remote.db absent).
# Subsequent container starts ignore these values.
#
# If KANBAN_ADMIN_PASSWORD is left blank, a secure password is auto-generated
# and printed to docker logs on first boot. Save it — it is only shown once.

KANBAN_ADMIN_EMAIL=admin@example.com
KANBAN_ADMIN_PASSWORD=

# ── Authentication ────────────────────────────────────────────────────────────
#
# Controls which login methods are available to remote users.
#
#   workos   — Cline account (WorkOS OAuth) only
#   password — Email + password only
#   both     — Either method (default)

KANBAN_AUTH_MODE=both

# WorkOS allowlist — comma-separated email addresses permitted to log in.
# Leave blank to allow any authenticated Cline account holder.
# Example: KANBAN_ALLOWED_EMAILS=alice@example.com,bob@example.com
KANBAN_ALLOWED_EMAILS=

# WorkOS domain allowlist — comma-separated domains whose members can log in.
# Leave blank for no domain restriction.
# Example: KANBAN_ALLOWED_DOMAINS=mycompany.com
KANBAN_ALLOWED_DOMAINS=

# ── Network ───────────────────────────────────────────────────────────────────

KANBAN_RUNTIME_HOST=0.0.0.0
KANBAN_RUNTIME_PORT=3484

# Public base URL — required for two features:
#   1. "Sign in with Cline" OAuth relay (GET /auth/start)
#   2. QR code generation in the settings panel
# Example: KANBAN_PUBLIC_URL=https://kanban.mycompany.com
# Leave blank if you're only using password login or accessing via Cloudflare tunnel.
KANBAN_PUBLIC_URL=

# ── Git identity ──────────────────────────────────────────────────────────────
#
# Used when Kanban creates commits inside managed repositories
# (e.g. initial commits, worktree setup). Does not affect agent-created commits.

GIT_AUTHOR_NAME=Cline Kanban
GIT_AUTHOR_EMAIL=kanban@local

# ── HTTPS / TLS ───────────────────────────────────────────────────────────────
#
# Mount CA-signed TLS certificates so push notifications and PWA features work
# correctly over HTTPS. Tailscale users can generate valid certs with:
#   tailscale cert support-wizard-4.tail5c9635.ts.net
# Then mount the resulting .crt and .key files into the container (see
# docker-compose.yml for the volume mount example) and set these paths.
#
# If set, KANBAN_TLS_CERT + KANBAN_TLS_KEY take priority over --cert / --key CLI flags.
# Both must be set together or neither.
KANBAN_TLS_CERT=
KANBAN_TLS_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
#
# Optional: set an explicit secret key used to encrypt session signing material
# at rest in remote.db. If not set, a stable key is automatically generated and
# stored in the data volume on first boot.
#
# Only needed if you want to pre-configure the key (e.g. for key rotation or
# if you're moving the data volume between different machines).
#
# Generate a strong key with: openssl rand -hex 32
KANBAN_SECRET_KEY=

# ── Behaviour ─────────────────────────────────────────────────────────────────

# Disable runtime npm auto-update (recommended for containers)
KANBAN_NO_AUTO_UPDATE=1

NODE_ENV=production
